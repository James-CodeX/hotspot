# PHPNuxBill — Environment Configuration
# Copy this file to .env and fill in your values.
# These env vars override any values written by the installer into config.php.

# ─── Timezone ────────────────────────────────────────────────────────────────
TZ=UTC

# ─── Database ────────────────────────────────────────────────────────────────

# Local MySQL (default)
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASS=secret
# DB_NAME=phpnuxbill
# DB_SSL=false
# DB_SSL_CA=

# Aiven Cloud MySQL (example)
DB_HOST=phpnuxbill-xx.k.aivencloud.com
DB_PORT=26019
DB_USER=avnadmin
DB_PASS=your-aiven-password-here
DB_NAME=defaultdb

# SSL — Aiven requires SSL. Set DB_SSL=true.
# For full cert verification, also set DB_SSL_CA to the path of the CA cert
# you downloaded from the Aiven console ("CA certificate → Download").
# Store it somewhere outside the web root, e.g. /etc/ssl/aiven-ca.pem
DB_SSL=true
DB_SSL_CA=/etc/ssl/aiven-ca.pem

# ─── FreeRadius (optional) ───────────────────────────────────────────────────
# Only needed if you enabled Radius during installation.
# Defaults to the same DB_* values above if not set.
# RADIUS_HOST=
# RADIUS_PORT=
# RADIUS_USER=
# RADIUS_PASS=
# RADIUS_NAME=
